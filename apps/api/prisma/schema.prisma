// Prisma schema — DevFlow
//
// Banco: PostgreSQL (Neon). Em produção (Vercel serverless) usamos o driver adapter
// da Neon (@prisma/adapter-neon), que dispensa o binário do query engine e conecta
// via WebSocket — ideal para funções serverless. Ver src/prisma/prisma.service.ts.
//
// A entidade-exemplo `Note` foi mantida como referência de padrão. Os modelos reais
// (Study, Project, Bug, Roadmap, ...) são adicionados conforme os módulos são
// implementados. Toda entidade segue a convenção de auditoria: createdAt/updatedAt.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Nomes das variáveis injetadas pela integração Neon do Vercel:
  // DATABASE_URL = conexão pooled (runtime/serverless)
  // DATABASE_URL_UNPOOLED = conexão direta (migrations)
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ─── Autenticação e Workspaces (times) ───────────────────────────────────────

/// Papel de um membro dentro de um workspace.
enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

/// Conta de usuário. A senha é guardada apenas como hash (bcrypt).
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String   @default("")

  memberships     Membership[]
  ownedWorkspaces Workspace[] // workspaces em que é dono (Workspace.owner)
  favorites       Favorite[]
  sentInvites     Invite[] // convites que este usuário enviou
  apiTokens       ApiToken[] // tokens de API (ex.: extensão do VSCode)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

/// Um workspace (time) — unidade de isolamento de TODOS os dados dos módulos.
/// `ownerId` é nulo enquanto o workspace-padrão dos dados legados não foi
/// reivindicado pelo primeiro registro (fluxo de "claim").
model Workspace {
  id      String  @id @default(cuid())
  name    String
  ownerId String?
  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  memberships Membership[]
  invites     Invite[]
  apiTokens   ApiToken[]

  // Dados isolados por workspace (entidades-raiz de cada módulo).
  notes        Note[]
  studies      Study[]
  projects     Project[]
  diaryEntries DiaryEntry[]
  knownErrors  KnownError[]
  wikiPages    WikiPage[]
  roadmaps     Roadmap[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("workspaces")
}

/// Vínculo usuário↔workspace com papel (base do multiusuário e dos times).
model Membership {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role        MembershipRole @default(MEMBER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, workspaceId])
  @@index([workspaceId])
  @@map("memberships")
}

/// Convite para entrar num workspace, aceito por link (token). O e-mail é um
/// rótulo/hint; a posse do token é o segredo que autoriza a aceitação.
model Invite {
  id          String         @id @default(cuid())
  workspaceId String
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email       String         @default("")
  role        MembershipRole @default(MEMBER)
  token       String         @unique
  invitedById String
  invitedBy   User           @relation(fields: [invitedById], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  acceptedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([token])
  @@map("invites")
}

/// Token de API pessoal (ex.: extensão do VSCode). Guarda apenas o hash; o token
/// embute o workspace, então autentica e escopa sem o header x-workspace-id.
model ApiToken {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String    @default("")
  tokenHash   String    @unique
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([workspaceId])
  @@map("api_tokens")
}

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String   @default("")

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@map("notes")
}

// ─── Módulo Estudos ──────────────────────────────────────────────────────────

/// Situação do estudo no fluxo de aprendizado.
enum StudyStatus {
  PLANNED
  IN_PROGRESS
  PAUSED
  COMPLETED
}

/// Nível de profundidade/domínio do estudo.
enum StudyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

/// Um estudo (ex.: "HTML", "React Hooks") com objetivos, anotações e metadados.
model Study {
  id           String      @id @default(cuid())
  name         String
  category     String      @default("")
  technology   String      @default("")
  description  String      @default("")
  notes        String      @default("") // Anotações em Markdown
  status       StudyStatus @default(PLANNED)
  level        StudyLevel  @default(BEGINNER)
  tags         String[]    @default([])
  links        Json        @default("[]") // [{ label, url }]
  hoursStudied Float       @default(0)
  startDate    DateTime?

  objectives StudyObjective[]
  sections   StudySection[]
  codeFiles  StudyCodeFile[]
  projects   Project[] // projetos vinculados a este estudo (n-n)

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@map("studies")
}

/// Arquivo de código guardado dentro de um estudo (nome + linguagem + conteúdo).
model StudyCodeFile {
  id       String @id @default(cuid())
  studyId  String
  study    Study  @relation(fields: [studyId], references: [id], onDelete: Cascade)
  name     String // ex.: "exemplo.tsx"
  language String @default("") // ex.: "tsx", "python"
  content  String @default("") // o código
  position Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studyId])
  @@map("study_code_files")
}

/// Seção de conteúdo de um estudo (card com título + Markdown, ex.: código).
model StudySection {
  id       String @id @default(cuid())
  studyId  String
  study    Study  @relation(fields: [studyId], references: [id], onDelete: Cascade)
  title    String
  content  String @default("") // Markdown (suporta código com realce)
  position Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studyId])
  @@map("study_sections")
}

/// Item de checklist (objetivo) de um estudo.
model StudyObjective {
  id       String  @id @default(cuid())
  studyId  String
  study    Study   @relation(fields: [studyId], references: [id], onDelete: Cascade)
  title    String
  done     Boolean @default(false)
  position Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studyId])
  @@map("study_objectives")
}

// ─── Módulo Projetos ─────────────────────────────────────────────────────────

/// Situação do projeto no ciclo de desenvolvimento.
enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  PAUSED
  COMPLETED
  ARCHIVED
}

/// Prioridade do projeto.
enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

/// Um projeto de software com visão geral, objetivos e links externos. Sub-módulos
/// (tarefas, bugs, versões, docs) serão adicionados em etapas futuras.
model Project {
  id           String          @id @default(cuid())
  name         String
  description  String          @default("") // Visão geral (Markdown)
  client       String          @default("")
  category     String          @default("")
  technologies String[]        @default([])
  status       ProjectStatus   @default(PLANNING)
  priority     ProjectPriority @default(MEDIUM)
  version      String          @default("")
  repoUrl      String          @default("") // GitHub/GitLab (repositório)
  figmaUrl     String          @default("")
  deployUrl    String          @default("")
  docsUrl      String          @default("")
  startDate    DateTime?
  deadline     DateTime?

  // Git (sem integração ainda — campos manuais)
  gitBranch   String   @default("")
  lastCommit  String   @default("")
  nextVersion String   @default("")
  gitTags     String[] @default([])

  objectives   ProjectObjective[]
  tasks        Task[]
  bugs         Bug[]
  docs         ProjectDoc[]
  versions     ProjectVersion[]
  diary        DiaryEntry[]
  ideas        Idea[]
  architecture ProjectArchitecture?
  studies      Study[] // estudos que vinculam este projeto (n-n)

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@map("projects")
}

/// Documentação de arquitetura de um projeto (1-1): diagramas (Mermaid),
/// estrutura de pastas e dependências.
model ProjectArchitecture {
  id              String  @id @default(cuid())
  projectId       String  @unique
  project         Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  content         String  @default("") // Markdown com Mermaid (diagramas, DB, APIs, fluxos)
  folderStructure String  @default("") // árvore de pastas (texto)
  dependencies    Json    @default("[]") // [{ name, version }]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("project_architectures")
}

/// Item de checklist (objetivo) da visão geral de um projeto.
model ProjectObjective {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  done      Boolean @default(false)
  position  Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@map("project_objectives")
}

/// Coluna do quadro Kanban em que a tarefa se encontra.
enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  TESTING
  DONE
}

/// Prioridade da tarefa.
enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

/// Tarefa de um projeto, posicionada em uma coluna do Kanban.
model Task {
  id             String       @id @default(cuid())
  projectId      String
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title          String
  description    String       @default("")
  status         TaskStatus   @default(BACKLOG)
  priority       TaskPriority @default(MEDIUM)
  assignee       String       @default("")
  estimatedHours Float        @default(0)
  spentHours     Float        @default(0)
  position       Int          @default(0) // ordem dentro da coluna

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([projectId, status])
  @@map("tasks")
}

// ─── Sub-módulo Banco de Ideias ──────────────────────────────────────────────

/// Nível de impacto/complexidade/prioridade de uma ideia.
enum IdeaRating {
  LOW
  MEDIUM
  HIGH
}

/// Situação de uma ideia no funil.
enum IdeaStatus {
  NEW
  CONSIDERING
  PLANNED
  DONE
  DISCARDED
}

/// Ideia futura de um projeto, com prioridade, impacto e complexidade.
model Idea {
  id          String     @id @default(cuid())
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String     @default("")
  priority    IdeaRating @default(MEDIUM)
  impact      IdeaRating @default(MEDIUM)
  complexity  IdeaRating @default(MEDIUM)
  status      IdeaStatus @default(NEW)
  tags        String[]   @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@map("ideas")
}

// ─── Sub-módulo Bugs ─────────────────────────────────────────────────────────

/// Gravidade do impacto do bug.
enum BugSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

/// Prioridade de correção do bug.
enum BugPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

/// Situação do bug no fluxo de correção.
enum BugStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  WONT_FIX
}

/// Registro de bug de um projeto.
model Bug {
  id                String      @id @default(cuid())
  projectId         String
  project           Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title             String
  description       String      @default("")
  severity          BugSeverity @default(MEDIUM)
  priority          BugPriority @default(MEDIUM)
  status            BugStatus   @default(OPEN)
  version           String      @default("") // versão em que ocorre
  module            String      @default("") // módulo afetado
  stepsToReproduce  String      @default("")
  expectedResult    String      @default("")
  actualResult      String      @default("")
  logs              String      @default("")
  fix               String      @default("") // descrição da correção
  fixedBy           String      @default("") // quem corrigiu

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([projectId, status])
  @@map("bugs")
}

/// Página de documentação (Markdown) de um projeto.
model ProjectDoc {
  id        String @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  content   String  @default("") // Markdown
  position  Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@map("project_docs")
}

// ─── Favoritos transversais ──────────────────────────────────────────────────

/// Tipo de entidade favoritável.
enum FavoriteType {
  STUDY
  PROJECT
  ROADMAP
  WIKI
  ERROR
}

/// Favorito (polimórfico) — aponta para uma entidade de qualquer módulo.
model Favorite {
  id       String       @id @default(cuid())
  type     FavoriteType
  entityId String
  title    String
  subtitle String       @default("")
  url      String // rota no app (ex.: /estudos/:id)

  // Favoritos são por usuário. Nullable só durante o backfill da migração;
  // preenchido no "claim" do primeiro registro.
  userId String?
  user   User?  @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, type, entityId])
  @@index([userId])
  @@map("favorites")
}

// ─── Módulo Diário de Desenvolvimento ────────────────────────────────────────

/// Registro de uma sessão de desenvolvimento/estudo.
model DiaryEntry {
  id           String   @id @default(cuid())
  date         DateTime @default(now())
  minutesSpent Int      @default(0)
  done         String   @default("") // O que foi feito
  problems     String   @default("") // Problemas encontrados
  solutions    String   @default("") // Como resolveu
  nextSteps    String   @default("") // Próximos passos
  mood         Int      @default(3) // Humor 1–5
  productivity Int      @default(3) // Produtividade 1–5

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([workspaceId])
  @@map("diary_entries")
}

// ─── Módulo Banco de Erros ───────────────────────────────────────────────────

/// Erro conhecido, com motivo e solução — base pesquisável.
model KnownError {
  id         String   @id @default(cuid())
  title      String // o erro
  cause      String   @default("") // motivo
  solution   String   @default("") // solução
  technology String   @default("")
  category   String   @default("")
  tags       String[] @default([])

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([workspaceId])
  @@map("known_errors")
}

// ─── Módulo Conhecimento (Wiki) ──────────────────────────────────────────────

/// Página da wiki pessoal (conhecimento) em Markdown.
model WikiPage {
  id        String   @id @default(cuid())
  title     String
  content   String   @default("") // Markdown
  category  String   @default("")
  tags      String[] @default([])
  favorite  Boolean  @default(false)

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([workspaceId])
  @@map("wiki_pages")
}

// ─── Módulo Roadmaps ─────────────────────────────────────────────────────────

/// Trilha de aprendizado com itens ordenados e progresso.
model Roadmap {
  id          String  @id @default(cuid())
  name        String
  description String  @default("")
  category    String  @default("")
  tags        String[] @default([])

  items RoadmapItem[]

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@map("roadmaps")
}

/// Item de uma trilha (ex.: "HTML", "React") com recursos e tempo recomendado.
model RoadmapItem {
  id              String  @id @default(cuid())
  roadmapId       String
  roadmap         Roadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  title           String
  description     String  @default("")
  links           Json    @default("[]") // [{ label, url }]
  recommendedTime String  @default("") // ex.: "2 semanas"
  done            Boolean @default(false)
  position        Int     @default(0)

  // Sub-itens (aninhamento de 1 nível, estilo roadmap.sh). Nulo = tópico raiz.
  parentId String?
  parent   RoadmapItem?  @relation("RoadmapItemChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children RoadmapItem[] @relation("RoadmapItemChildren")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roadmapId])
  @@index([parentId])
  @@map("roadmap_items")
}

/// Uma versão registrada de um projeto (base do changelog).
model ProjectVersion {
  id           String    @id @default(cuid())
  projectId    String
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version      String // ex.: "1.3.0"
  description  String    @default("")
  releasedAt   DateTime?
  features     String    @default("") // Novidades (um item por linha)
  fixes        String    @default("") // Correções
  improvements String    @default("") // Melhorias
  breaking     String    @default("") // Breaking changes

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@map("project_versions")
}
