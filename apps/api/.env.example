# Porta do servidor NestJS (dev local)
PORT=3000

# Origem permitida no CORS (dev server do Vite)
WEB_ORIGIN=http://localhost:5173

# PostgreSQL (Neon).
# DATABASE_URL: conexão "pooled" (host com -pooler) — usada em runtime/serverless.
# DIRECT_URL:   conexão direta (sem -pooler) — usada pelas migrations do Prisma.
# Crie um banco NOVO no Neon (ex.: "bytedesk"); não reutilize bancos de outros projetos.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/bytedesk?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/bytedesk?sslmode=require"
