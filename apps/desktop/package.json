{
  "name": "@bytedesk/desktop",
  "version": "1.0.0",
  "private": true,
  "description": "ByteDesk — app desktop (Windows)",
  "author": "ByteDesk",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --publish never"
  },
  "build": {
    "appId": "com.bytedesk.app",
    "productName": "ByteDesk",
    "copyright": "© ByteDesk",
    "files": ["main.js"],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "ByteDesk-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "ByteDesk-${version}-portable.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  }
}
