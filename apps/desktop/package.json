{
  "name": "@devflow/desktop",
  "version": "1.0.0",
  "private": true,
  "description": "DevFlow — app desktop (Windows)",
  "author": "ByteDesk",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --publish never"
  },
  "build": {
    "appId": "com.bytedesk.devflow",
    "productName": "DevFlow",
    "copyright": "© ByteDesk",
    "files": ["main.js"],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": ["nsis", "portable"]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "DevFlow-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "DevFlow-${version}-portable.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  }
}
